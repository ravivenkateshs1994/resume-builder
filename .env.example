# Example .env file — DO NOT COMMIT
# Copy to .env.local and fill in secrets

# Required (server + AI)
GEMINI_API_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional (admin seeding)
SUPABASE_ADMIN_EMAIL=
SUPABASE_ADMIN_PASSWORD=

# Feature flags (toggle UI/behavior)
FEATURE_PREMIUM_TEMPLATES=off
NEXT_PUBLIC_FEATURE_PREMIUM_TEMPLATES=off

# Puppeteer / PDF export
PUPPETEER_BASE_URL=http://localhost:3000
PUPPETEER_CACHE_DIR=
PUPPETEER_EXECUTABLE_PATH=
CHROME_PATH=
CHROMIUM_PATH=
EDGE_PATH=

# Debug helpers
DEBUG_SUPABASE_AUTH=0
